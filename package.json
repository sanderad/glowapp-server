{
  "name": "glowapp-server",
  "version": "1.0.0",
  "description": "Backend for GlowApp",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node --files src/index.ts",
    "build": "tsc",
    "typeorm": "typeorm-ts-node-commonjs",
    "m:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/data-source.ts",
    "m:run": "typeorm-ts-node-commonjs migration:run -d src/config/data-source.ts",
    "m:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/data-source.ts",
    "kill": "kill $(lsof -t -i:5000)"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "inversify": "^6.0.1",
    "inversify-express-utils": "^6.4.6",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.0",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.17",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.0",
    "@types/socket.io": "^3.0.1",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  }
}
